# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
QUERY_LLM_MODEL=  # Query pipeline model (agentic reasoning + citations). Falls back to LLM_MODEL if empty.
VLLM_BASE_URL=http://localhost:8080/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# === Embedding ===
EMBEDDING_PROVIDER=openai  # openai | local | tei | gemini | ollama
EMBEDDING_MODEL=text-embedding-3-large
GEMINI_EMBEDDING_MODEL=gemini-embedding-exp-03-07
EMBEDDING_DIMENSIONS=1024
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# TEI_EMBEDDING_URL=http://localhost:8081  # For EMBEDDING_PROVIDER=tei (M17 local deployment)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text  # For EMBEDDING_PROVIDER=ollama (uses OLLAMA_BASE_URL)
ENABLE_VISUAL_EMBEDDINGS=false
VISUAL_EMBEDDING_MODEL=vidore/colqwen2.5-v0.2
VISUAL_EMBEDDING_DEVICE=mps
VISUAL_EMBEDDING_BATCH_SIZE=4
VISUAL_EMBEDDING_DIM=128
VISUAL_RERANK_WEIGHT=0.3
VISUAL_RERANK_TOP_N=20
VISUAL_PAGE_DPI=144

# === PostgreSQL ===
POSTGRES_URL=postgresql+asyncpg://nexus:changeme@localhost:5432/nexus
POSTGRES_URL_SYNC=postgresql://nexus:changeme@localhost:5432/nexus
POSTGRES_PASSWORD=changeme

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant ===
QDRANT_URL=http://localhost:6333

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nexus-admin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# === Processing ===
CELERY_CONCURRENCY=1
CHUNK_SIZE=512
CHUNK_OVERLAP=64
GLINER_MODEL=urchade/gliner_multi_pii-v1
ENABLE_RELATIONSHIP_EXTRACTION=false

# === Sparse Embeddings ===
ENABLE_SPARSE_EMBEDDINGS=false
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions

# === Retrieval Tuning ===
RETRIEVAL_TEXT_LIMIT=20
RETRIEVAL_GRAPH_LIMIT=20
RETRIEVAL_PREFETCH_MULTIPLIER=2
QUERY_ENTITY_THRESHOLD=0.5

# === Reranker ===
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=10
# RERANKER_PROVIDER=local  # local | tei (M17 local deployment)
# TEI_RERANKER_URL=http://localhost:8082  # For RERANKER_PROVIDER=tei

# === Auth ===
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Multi-Tenancy ===
REQUIRE_MATTER_HEADER=true

# === Embedding Batch Size ===
EMBEDDING_BATCH_SIZE=100

# === Email Threading ===
ENABLE_EMAIL_THREADING=true

# === Near-Duplicate Detection ===
ENABLE_NEAR_DUPLICATE_DETECTION=true
DEDUP_JACCARD_THRESHOLD=0.80
DEDUP_NUM_PERMUTATIONS=128

# === Audit (SOC 2) ===
AUDIT_RETENTION_DAYS=365
ENABLE_AI_AUDIT_LOGGING=true

# === Batch Embeddings (stub — real-time embedding used for now) ===
ENABLE_BATCH_EMBEDDINGS=false
BATCH_EMBEDDINGS_POLL_INTERVAL=60

# === Coreference Resolution (M11) ===
ENABLE_COREFERENCE_RESOLUTION=false
COREFERENCE_MODEL=en_core_web_lg

# === Graph Centrality (M11) ===
ENABLE_GRAPH_CENTRALITY=false

# === Case Intelligence ===
ENABLE_CASE_SETUP_AGENT=false

# === Agentic Pipeline ===
ENABLE_AGENTIC_PIPELINE=true
ENABLE_CITATION_VERIFICATION=true
AGENTIC_RECURSION_LIMIT_FAST=16
AGENTIC_RECURSION_LIMIT_STANDARD=28
AGENTIC_RECURSION_LIMIT_DEEP=50

# === Hot Doc Detection (M10b) ===
ENABLE_HOT_DOC_DETECTION=false
HOT_DOC_SCORE_THRESHOLD=0.6

# === LangSmith Tracing ===
# Enables full pipeline traces (node timing, tool calls, token counts) in LangSmith UI.
# LangGraph + ChatAnthropic pick these up automatically — zero code changes needed.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=nexus

# === Logging ===
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# === Google Drive Integration ===
ENABLE_GOOGLE_DRIVE=false
# GDRIVE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GDRIVE_CLIENT_SECRET=your-oauth-client-secret
GDRIVE_REDIRECT_URI=http://localhost:5173/gdrive/callback
# GDRIVE_ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GDRIVE_MAX_CONCURRENT_DOWNLOADS=10

# === Chunk Quality Scoring ===
ENABLE_CHUNK_QUALITY_SCORING=false

# === Contextual Chunk Enrichment ===
# LLM-generated context prefix per chunk at ingestion time (improves retrieval).
# Uses the "ingestion" LLM tier from /admin/llm-settings. Set tier to Ollama for zero-cost testing.
ENABLE_CONTEXTUAL_CHUNKS=false
CONTEXTUAL_CHUNK_MODEL=            # Override model (empty = use ingestion tier)
CONTEXTUAL_CHUNK_MAX_TOKENS=100
CONTEXTUAL_CHUNK_BATCH_SIZE=20
CONTEXTUAL_CHUNK_CONCURRENCY=4

# === Retrieval Grading (CRAG) ===
# Two-tier retrieval relevance grading: heuristic pre-scoring + conditional LLM grading.
# Uses the "query" LLM tier from /admin/llm-settings. Set tier to Ollama for zero-cost testing.
ENABLE_RETRIEVAL_GRADING=false
GRADING_MODEL=                     # Override model (empty = use query tier)
GRADING_CONFIDENCE_THRESHOLD=0.5

# === Redaction (M14b) ===
ENABLE_REDACTION=false

# === Prometheus Metrics ===
ENABLE_PROMETHEUS_METRICS=true

# === Memo Drafting ===
ENABLE_MEMO_DRAFTING=false

# === Communication Analytics (M10c) ===
ENABLE_TOPIC_CLUSTERING=false
BERTOPIC_EMBEDDING_MODEL=all-MiniLM-L6-v2
BERTOPIC_MIN_CLUSTER_SIZE=5

# === SSO / OIDC ===
ENABLE_SSO=false
OIDC_PROVIDER_NAME=SSO
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=
OIDC_REDIRECT_URI=http://localhost:5173/auth/oidc/callback
OIDC_ROLE_MAPPING={}
OIDC_DEFAULT_ROLE=reviewer

# === SSO / SAML ===
ENABLE_SAML=false
SAML_ENTITY_ID=                    # SP entity ID (e.g. https://nexus.example.com/saml)
SAML_IDP_METADATA_URL=             # IdP metadata URL (optional, for auto-config)
SAML_IDP_SSO_URL=                  # IdP SSO endpoint URL
SAML_IDP_CERT=                     # IdP X.509 certificate (PEM, newlines replaced with \n)
SAML_SP_CERT=                      # SP certificate (optional, for signed AuthnRequests)
SAML_SP_KEY=                       # SP private key (optional, for signed AuthnRequests)
SAML_ROLE_MAPPING={}               # JSON: {"admin_group": "admin", "attorney_group": "attorney"}
SAML_DEFAULT_ROLE=viewer           # Role for users with no group mapping

# === Multi-Query Expansion ===
ENABLE_MULTI_QUERY_EXPANSION=false
MULTI_QUERY_COUNT=3

# === Text-to-Cypher Generation ===
ENABLE_TEXT_TO_CYPHER=false

# === Semantic Prompt Routing ===
ENABLE_PROMPT_ROUTING=false

# === Question Decomposition ===
ENABLE_QUESTION_DECOMPOSITION=false

# === Data Retention ===
ENABLE_DATA_RETENTION=false

# === HyDE (Hypothetical Document Embeddings) ===
ENABLE_HYDE=false
HYDE_MODEL=                          # Override model (empty = use default LLM)

# === Self-Reflection Loop ===
ENABLE_SELF_REFLECTION=false
SELF_REFLECTION_FAITHFULNESS_THRESHOLD=0.8
SELF_REFLECTION_MAX_RETRIES=1

# === RRF Per-Modality Prefetch Multipliers ===
RETRIEVAL_DENSE_PREFETCH_MULTIPLIER=2
RETRIEVAL_SPARSE_PREFETCH_MULTIPLIER=2

# === Text-to-SQL Generation ===
ENABLE_TEXT_TO_SQL=false

# === Document Summarization ===
ENABLE_DOCUMENT_SUMMARIZATION=false

# === Multi-Representation Indexing ===
ENABLE_MULTI_REPRESENTATION=false
MULTI_REPRESENTATION_CONCURRENCY=4

# === Production Quality Monitoring ===
ENABLE_PRODUCTION_QUALITY_MONITORING=false
QUALITY_MONITORING_SAMPLE_RATE=0.1

# === Cloud Deployment ===
# DOMAIN=api.nexus-demo.com  # Used by Caddy for TLS provisioning (cloud deploy only)

# === Flower Monitoring ===
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
