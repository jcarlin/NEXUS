# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
VLLM_BASE_URL=http://localhost:8080/v1

# === Embedding ===
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ENABLE_VISUAL_EMBEDDINGS=false

# === PostgreSQL ===
POSTGRES_URL=postgresql+asyncpg://nexus:changeme@localhost:5432/nexus
POSTGRES_URL_SYNC=postgresql://nexus:changeme@localhost:5432/nexus
POSTGRES_PASSWORD=changeme

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant ===
QDRANT_URL=http://localhost:6333

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nexus-admin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# === Processing ===
CELERY_CONCURRENCY=1
CHUNK_SIZE=512
CHUNK_OVERLAP=64
GLINER_MODEL=urchade/gliner_multi_pii-v1
ENABLE_RELATIONSHIP_EXTRACTION=false

# === Sparse Embeddings ===
ENABLE_SPARSE_EMBEDDINGS=false
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions

# === Reranker ===
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=10

# === Auth ===
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Multi-Tenancy ===
REQUIRE_MATTER_HEADER=true

# === Embedding Batch Size ===
EMBEDDING_BATCH_SIZE=100
