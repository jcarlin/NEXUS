# Auto-generated for NEXUS cloud deploy
ANTHROPIC_API_KEY=<your-key>
OPENAI_API_KEY=<your-key>
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
EMBEDDING_PROVIDER=infinity
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=100
POSTGRES_PASSWORD=<your-password>
NEO4J_PASSWORD=<your-password>
MINIO_ACCESS_KEY=nexus-admin
MINIO_SECRET_KEY=<your-secret>
MINIO_BUCKET=documents
MINIO_USE_SSL=false
JWT_SECRET_KEY=<random-64-char-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ALLOWED_ORIGINS=https://nexus-alpha-swart.vercel.app
REQUIRE_MATTER_HEADER=true
CELERY_CONCURRENCY=3
NER_WORKER_CONCURRENCY=4
CHUNK_SIZE=512
CHUNK_OVERLAP=64
ENABLE_AGENTIC_PIPELINE=true
ENABLE_CITATION_VERIFICATION=true
ENABLE_EMAIL_THREADING=true
ENABLE_VISUAL_EMBEDDINGS=false
ENABLE_RELATIONSHIP_EXTRACTION=true
ENABLE_RERANKER=true
ENABLE_SPARSE_EMBEDDINGS=true
ENABLE_AI_AUDIT_LOGGING=true

# Rate limits (relaxed for demo)
RATE_LIMIT_QUERIES_PER_MINUTE=120
RATE_LIMIT_INGESTS_PER_MINUTE=60
# Additional features (enabled for demo)
ENABLE_NEAR_DUPLICATE_DETECTION=true
ENABLE_COREFERENCE_RESOLUTION=false
ENABLE_GRAPH_CENTRALITY=true
ENABLE_CASE_SETUP_AGENT=true
ENABLE_HOT_DOC_DETECTION=true
ENABLE_REDACTION=true
ENABLE_TOPIC_CLUSTERING=true
ENABLE_MEMO_DRAFTING=true
ENABLE_SERVICE_OPERATIONS=true
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_COMPOSE_PROJECT=nexus
ENABLE_PROMPT_ROUTING=true
ENABLE_HALLUGRAPH_ALIGNMENT=true
ENABLE_ADAPTIVE_RETRIEVAL_DEPTH=true
QUERY_LLM_MODEL=gemini-2.5-pro
GEMINI_API_KEY=<your-key>
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Flower (Celery monitoring dashboard)
FLOWER_USER=admin
FLOWER_PASSWORD=<your-password>
DOCKER_GID=113
RERANKER_PROVIDER=infinity
INFINITY_URL=http://infinity:7997
INFINITY_EMBEDDING_MODEL=BAAI/bge-m3
INFINITY_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
