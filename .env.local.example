# === .env.local — Full Local Deployment (Zero Cloud API Dependency) ===
# Copy to .env.local and adjust as needed.
# Usage: docker compose -f docker-compose.yml -f docker-compose.local.yml up -d

# --- LLM (vLLM — local) ---
# No ANTHROPIC_API_KEY or OPENAI_API_KEY needed.
LLM_PROVIDER=vllm
VLLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=Qwen/Qwen3-235B-A22B
VLLM_MODEL=Qwen/Qwen3-235B-A22B
VLLM_TP_SIZE=1
VLLM_MAX_MODEL_LEN=8192

# --- Embeddings (TEI — local) ---
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
TEI_EMBEDDING_MODEL=BAAI/bge-m3

# --- Reranker (TEI — local) ---
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
TEI_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- HuggingFace Token (required for gated models) ---
HF_TOKEN=

# --- PostgreSQL ---
POSTGRES_URL=postgresql+asyncpg://nexus:changeme@localhost:5432/nexus
POSTGRES_URL_SYNC=postgresql://nexus:changeme@localhost:5432/nexus
POSTGRES_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nexus-admin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# --- Processing ---
CELERY_CONCURRENCY=1
CHUNK_SIZE=512
CHUNK_OVERLAP=64
GLINER_MODEL=urchade/gliner_multi_pii-v1
ENABLE_RELATIONSHIP_EXTRACTION=false

# --- Sparse Embeddings ---
ENABLE_SPARSE_EMBEDDINGS=false
SPARSE_EMBEDDING_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions

# --- Retrieval Tuning ---
RETRIEVAL_TEXT_LIMIT=20
RETRIEVAL_GRAPH_LIMIT=20
RETRIEVAL_PREFETCH_MULTIPLIER=2
QUERY_ENTITY_THRESHOLD=0.5

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Multi-Tenancy ---
REQUIRE_MATTER_HEADER=true

# --- Feature Flags ---
ENABLE_VISUAL_EMBEDDINGS=false
ENABLE_AGENTIC_PIPELINE=true
ENABLE_CITATION_VERIFICATION=true
ENABLE_HOT_DOC_DETECTION=false
ENABLE_REDACTION=false
ENABLE_TOPIC_CLUSTERING=false
ENABLE_AI_AUDIT_LOGGING=true
