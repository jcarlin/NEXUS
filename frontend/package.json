    "@testing-library/dom": "^10.4.1",
    "@uppy/aws-s3": "^4.2.1",
    "@uppy/core": "^4.4.1",
    "@uppy/dashboard": "^4.3.1",
    "@uppy/drag-drop": "^4.2.2",
    "@uppy/file-input": "^4.2.2",
    "@uppy/progress-bar": "^4.3.2",
